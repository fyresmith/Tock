{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tock",
  "version": "0.5.1",
  "identifier": "com.calebsmith.tock",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tock",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/fyresmith/Tock/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdGN0QyQjdCODNGOEFCRDMKUldUVHEvaURleXQ5Zjc1aFRpdFpyWnZXWHZQdTFsY29qRE5hcEt4bEYxdTcrRktmNHlMRlVnQ2kK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
